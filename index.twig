<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LiteView — Route Explorer</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #F5F3EF;
            --surface: #FFFFFF;
            --text: #1C1917;
            --text-secondary: #78716C;
            --text-muted: #A8A29E;
            --accent: #C2410C;
            --accent-hover: #9A3412;
            --accent-light: #FFF7ED;
            --border: #E7E5E4;
            --border-light: #F0EEEC;
            --code-bg: #F5F3EF;
            --get: #059669;
            --get-bg: #ECFDF5;
            --post: #2563EB;
            --post-bg: #EFF6FF;
            --put: #B45309;
            --put-bg: #FFFBEB;
            --delete: #DC2626;
            --delete-bg: #FEF2F2;
            --any: #7C3AED;
            --any-bg: #F5F3FF;
            --radius: 8px;
            --shadow-sm: 0 1px 2px rgba(0,0,0,0.04);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Outfit', sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            -webkit-font-smoothing: antialiased;
        }

        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: var(--accent);
            z-index: 100;
        }

        .container {
            max-width: 820px;
            margin: 0 auto;
            padding: 56px 24px 80px;
        }

        .header {
            margin-bottom: 44px;
            animation: slideDown 0.5s ease both;
        }

        .header-title {
            font-size: 2.5rem;
            font-weight: 700;
            letter-spacing: -1px;
            line-height: 1.1;
        }

        .header-title span {
            color: var(--accent);
        }

        .header-sub {
            font-size: 1rem;
            font-weight: 300;
            color: var(--text-secondary);
            margin-top: 6px;
        }

        .header-count {
            display: inline-flex;
            align-items: center;
            margin-top: 14px;
            font-size: 0.72rem;
            font-weight: 500;
            color: var(--accent);
            background: var(--accent-light);
            padding: 3px 12px;
            border-radius: 100px;
            border: 1px solid #FDBA74;
            font-family: 'JetBrains Mono', monospace;
        }

        .routes {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .route-row {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            overflow: hidden;
            transition: border-color 0.15s, box-shadow 0.15s;
            opacity: 0;
            transform: translateY(8px);
            animation: slideUp 0.35s ease forwards;
        }

        .route-row:hover {
            border-color: #D6D3D1;
            box-shadow: var(--shadow-sm);
        }

        .route-row.active {
            border-color: var(--accent);
            box-shadow: 0 2px 8px rgba(194,65,12,0.1);
        }

        .route-main {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 11px 16px;
        }

        .method {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.6rem;
            font-weight: 600;
            padding: 3px 7px;
            border-radius: 4px;
            text-transform: uppercase;
            letter-spacing: 0.4px;
            flex-shrink: 0;
            line-height: 1.4;
        }

        .m-get    { background: var(--get-bg);    color: var(--get); }
        .m-post   { background: var(--post-bg);   color: var(--post); }
        .m-put    { background: var(--put-bg);     color: var(--put); }
        .m-patch  { background: var(--put-bg);     color: var(--put); }
        .m-delete { background: var(--delete-bg);  color: var(--delete); }
        .m-any    { background: var(--any-bg);      color: var(--any); }

        .route-path {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.82rem;
            font-weight: 400;
            color: var(--text);
            flex: 1;
            min-width: 0;
        }

        .route-path a {
            color: var(--accent);
            text-decoration: none;
            border-bottom: 1px dashed #FDBA74;
            transition: border-color 0.15s, color 0.15s;
        }

        .route-path a:hover {
            color: var(--accent-hover);
            border-bottom-style: solid;
            border-bottom-color: var(--accent);
        }

        .route-action {
            font-size: 0.72rem;
            color: var(--text-muted);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 180px;
            font-family: 'JetBrains Mono', monospace;
        }

        .test-btn {
            font-family: 'Outfit', sans-serif;
            font-size: 0.7rem;
            font-weight: 500;
            padding: 4px 14px;
            border-radius: 5px;
            border: 1px solid var(--border);
            background: var(--surface);
            color: var(--text-secondary);
            cursor: pointer;
            transition: all 0.15s;
            flex-shrink: 0;
            line-height: 1.4;
        }

        .test-btn:hover {
            background: var(--accent);
            color: #fff;
            border-color: var(--accent);
        }

        a.test-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
        }

        .test-btn:active {
            transform: scale(0.97);
        }

        .test-btn.loading {
            opacity: 0.5;
            pointer-events: none;
        }

        .param-row {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 0 16px 12px;
            flex-wrap: wrap;
            animation: expandIn 0.2s ease;
        }

        .param-label {
            font-size: 0.72rem;
            color: var(--text-muted);
            font-family: 'JetBrains Mono', monospace;
        }

        .param-group {
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .param-group label {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.72rem;
            color: var(--text-muted);
        }

        .param-group input {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.78rem;
            padding: 3px 8px;
            border: 1px solid var(--border);
            border-radius: 5px;
            background: #FDFCF9;
            color: var(--text);
            outline: none;
            width: 90px;
            transition: border-color 0.15s;
        }

        .param-group input:focus {
            border-color: var(--accent);
        }

        .param-group input::placeholder {
            color: #C7C5C2;
        }

        .send-btn {
            font-family: 'Outfit', sans-serif;
            font-size: 0.7rem;
            font-weight: 500;
            padding: 4px 14px;
            border-radius: 5px;
            border: 1px solid var(--accent);
            background: var(--accent);
            color: #fff;
            cursor: pointer;
            transition: all 0.15s;
        }

        .send-btn:hover {
            background: var(--accent-hover);
        }

        .response-panel {
            border-top: 1px solid var(--border-light);
            padding: 12px 16px 14px;
            background: #FDFCF9;
            animation: expandIn 0.2s ease;
        }

        .response-meta {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 8px;
        }

        .status-badge {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.68rem;
            font-weight: 600;
            padding: 2px 8px;
            border-radius: 4px;
        }

        .status-2xx { background: var(--get-bg);    color: var(--get); }
        .status-3xx { background: var(--put-bg);     color: var(--put); }
        .status-4xx { background: var(--delete-bg);  color: var(--delete); }
        .status-5xx { background: var(--delete-bg);  color: var(--delete); }
        .status-err { background: var(--delete-bg);  color: var(--delete); }

        .response-time {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.68rem;
            color: var(--text-muted);
        }

        .close-btn {
            font-family: 'Outfit', sans-serif;
            font-size: 0.68rem;
            color: var(--text-muted);
            background: none;
            border: 1px solid var(--border);
            cursor: pointer;
            padding: 2px 8px;
            border-radius: 4px;
            margin-left: auto;
            transition: all 0.15s;
        }

        .close-btn:hover {
            color: var(--text);
            border-color: #D6D3D1;
        }

        .response-body {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.76rem;
            line-height: 1.55;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 6px;
            padding: 12px 14px;
            white-space: pre-wrap;
            word-break: break-all;
            max-height: 320px;
            overflow-y: auto;
            color: var(--text);
        }

        @keyframes slideDown {
            from { opacity: 0; transform: translateY(-12px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        @keyframes slideUp {
            from { opacity: 0; transform: translateY(8px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        @keyframes expandIn {
            from { opacity: 0; }
            to   { opacity: 1; }
        }

        .response-body::-webkit-scrollbar { width: 5px; }
        .response-body::-webkit-scrollbar-track { background: transparent; }
        .response-body::-webkit-scrollbar-thumb { background: #D6D3D1; border-radius: 3px; }

        .footer {
            text-align: center;
            margin-top: 56px;
            font-size: 0.78rem;
            color: var(--text-muted);
            font-weight: 300;
            animation: slideUp 0.5s ease 0.3s both;
        }

        .footer span { color: var(--accent); }

        @media (prefers-reduced-motion: reduce) {
            .header, .route-row, .footer { animation: none; opacity: 1; transform: none; }
        }

        @media (max-width: 640px) {
            .container { padding: 32px 16px 60px; }
            .header-title { font-size: 1.8rem; }
            .route-action { display: none; }
            .route-main { padding: 10px 12px; gap: 8px; }
        }
    </style>
</head>
<body>
<div class="container">
    <div class="header">
        <h1 class="header-title">Lite<span>View</span></h1>
        <p class="header-sub">Route Explorer &mdash; test all defined routes</p>
        <div class="header-count">10 routes registered</div>
    </div>

    <div class="routes" id="routes">
        <!-- GET /demo/visitor -->
        <div class="route-row" data-path="/demo/visitor">
            <div class="route-main">
                <span class="method m-get">GET</span>
                <span class="route-path">/demo/visitor</span>
                <span class="route-action">Closure</span>
                <a href="/demo/visitor" target="_blank" class="test-btn">Open</a>
            </div>
        </div>

        <!-- GET /demo/user/{id} -->
        <div class="route-row" data-path="/demo/user/{id}">
            <div class="route-main">
                <span class="method m-get">GET</span>
                <span class="route-path">/demo/user/{id}</span>
                <span class="route-action">Closure</span>
                <button class="test-btn" onclick="openRouteParams(this)">Open</button>
            </div>
        </div>

        <!-- GET /demo/file/{path} -->
        <div class="route-row" data-path="/demo/file/{path}">
            <div class="route-main">
                <span class="method m-get">GET</span>
                <span class="route-path">/demo/file/{path}</span>
                <span class="route-action">Closure</span>
                <button class="test-btn" onclick="openRouteParams(this)">Open</button>
            </div>
        </div>

        <!-- GET /demo/mw -->
        <div class="route-row" data-path="/demo/mw">
            <div class="route-main">
                <span class="method m-get">GET</span>
                <span class="route-path">/demo/mw</span>
                <span class="route-action">Closure</span>
                <a href="/demo/mw" target="_blank" class="test-btn">Open</a>
            </div>
        </div>

        <!-- GET /demo/error -->
        <div class="route-row" data-path="/demo/error">
            <div class="route-main">
                <span class="method m-get">GET</span>
                <span class="route-path">/demo/error</span>
                <span class="route-action">Closure</span>
                <a href="/demo/error" target="_blank" class="test-btn">Open</a>
            </div>
        </div>

        <!-- GET /api/users -->
        <div class="route-row" data-path="/api/users" data-method="GET">
            <div class="route-main">
                <span class="method m-get">GET</span>
                <span class="route-path">/api/users</span>
                <span class="route-action">DemoController@index</span>
                <button class="test-btn" onclick="testRoute(this)">Test</button>
            </div>
        </div>

        <!-- POST /api/users -->
        <div class="route-row" data-path="/api/users" data-method="POST">
            <div class="route-main">
                <span class="method m-post">POST</span>
                <span class="route-path">/api/users</span>
                <span class="route-action">DemoController@store</span>
                <button class="test-btn" onclick="testRoute(this)">Test</button>
            </div>
        </div>

        <!-- GET /api/users/{id} -->
        <div class="route-row" data-path="/api/users/{id}" data-method="GET">
            <div class="route-main">
                <span class="method m-get">GET</span>
                <span class="route-path">/api/users/{id}</span>
                <span class="route-action">DemoController@show</span>
                <button class="test-btn" onclick="testRoute(this)">Test</button>
            </div>
        </div>

        <!-- PUT /api/users/{id} -->
        <div class="route-row" data-path="/api/users/{id}" data-method="PUT">
            <div class="route-main">
                <span class="method m-put">PUT</span>
                <span class="route-path">/api/users/{id}</span>
                <span class="route-action">DemoController@update</span>
                <button class="test-btn" onclick="testRoute(this)">Test</button>
            </div>
        </div>

        <!-- DELETE /api/users/{id} -->
        <div class="route-row" data-path="/api/users/{id}" data-method="DELETE">
            <div class="route-main">
                <span class="method m-delete">DELETE</span>
                <span class="route-path">/api/users/{id}</span>
                <span class="route-action">DemoController@destroy</span>
                <button class="test-btn" onclick="testRoute(this)">Test</button>
            </div>
        </div>
    </div>

    <div class="footer">Lite<span>View</span> Framework</div>
</div>

<script>
(function () {
    var rows = document.querySelectorAll('.route-row');
    for (var i = 0; i < rows.length; i++) {
        rows[i].style.animationDelay = (i * 0.03) + 's';
    }
})();

function testRoute(btn) {
    var row = btn.closest('.route-row');
    var panel = row.querySelector('.response-panel');
    var params = row.querySelector('.param-row');

    if (panel) {
        panel.remove();
        if (params) params.remove();
        row.classList.remove('active');
        return;
    }
    if (params) {
        params.remove();
        row.classList.remove('active');
        return;
    }

    var method = row.dataset.method;
    var path = row.dataset.path;
    var hasParams = /\{[^}]+\}/.test(path);

    if (hasParams) {
        showParamInputs(row, method, path, btn);
    } else {
        sendRequest(row, method, path, btn);
    }
}

function openRouteParams(btn) {
    var row = btn.closest('.route-row');
    var params = row.querySelector('.param-row');
    if (params) {
        params.remove();
        row.classList.remove('active');
        return;
    }
    var path = row.dataset.path;
    showParamInputs(row, null, path, btn);
}

function removeRoutePanel(btn) {
    var row = btn.closest('.route-row');
    var panel = row.querySelector('.response-panel');
    if (panel) panel.remove();
    params = row.querySelector('.param-row');
    if (params) params.remove();
    row.classList.remove('active');
    var testBtn = row.querySelector('.test-btn');
    if (testBtn) testBtn.textContent = 'Test';
}

function showParamInputs(row, method, path, btn) {
    var matches = path.match(/\{[^}]+\}/g);
    if (!matches) return;

    var div = document.createElement('div');
    div.className = 'param-row';

    var label = document.createElement('span');
    label.className = 'param-label';
    label.textContent = 'Params:';
    div.appendChild(label);

    for (var i = 0; i < matches.length; i++) {
        var name = matches[i].replace(/[{}]/g, '');
        var group = document.createElement('div');
        group.className = 'param-group';

        var lbl = document.createElement('label');
        lbl.textContent = name;
        group.appendChild(lbl);

        var input = document.createElement('input');
        input.type = 'text';
        input.setAttribute('data-param', name);
        input.placeholder = name;
        group.appendChild(input);

        div.appendChild(group);
    }

    var isApi = row.hasAttribute('data-method');
    var actionBtn;
    if (isApi) {
        actionBtn = document.createElement('button');
        actionBtn.className = 'send-btn';
        actionBtn.textContent = 'Send';
        actionBtn.onclick = function () {
            var resolved = path;
            var inputs = div.querySelectorAll('input[data-param]');
            for (var j = 0; j < inputs.length; j++) {
                var p = inputs[j].getAttribute('data-param');
                var v = inputs[j].value || p;
                resolved = resolved.replace('{' + p + '}', encodeURIComponent(v));
            }
            div.remove();
            sendRequest(row, method, resolved, btn);
        };
    } else {
        actionBtn = document.createElement('a');
        actionBtn.href = '#';
        actionBtn.className = 'send-btn';
        actionBtn.style.textDecoration = 'none';
        actionBtn.target = '_blank';
        actionBtn.textContent = 'Open';
        actionBtn.onclick = function (e) {
            e.preventDefault();
            var resolved = path;
            var inputs = div.querySelectorAll('input[data-param]');
            for (var j = 0; j < inputs.length; j++) {
                var p = inputs[j].getAttribute('data-param');
                var v = inputs[j].value || p;
                resolved = resolved.replace('{' + p + '}', encodeURIComponent(v));
            }
            window.open(resolved, '_blank');
        };
    }
    div.appendChild(actionBtn);

    row.appendChild(div);
    row.classList.add('active');

    var first = div.querySelector('input');
    if (first) first.focus();

    div.addEventListener('keydown', function (e) {
        if (e.key === 'Enter') actionBtn.click();
    });
}

function sendRequest(row, method, path, btn) {
    btn.textContent = '...';
    btn.classList.add('loading');
    row.classList.add('active');

    var start = performance.now();
    var options = { method: method, headers: { 'Accept': 'application/json' } };
    if (method !== 'GET' && method !== 'HEAD') {
        options.headers['Content-Type'] = 'application/json';
        options.body = JSON.stringify({});
    }

    fetch(path, options)
        .then(function (r) {
            return r.text().then(function (body) {
                return { status: r.status, statusText: r.statusText, body: body, time: Math.round(performance.now() - start) };
            });
        })
        .then(function (result) {
            var display = result.body;
            try { display = JSON.stringify(JSON.parse(result.body), null, 2); } catch (e) {}
            showResponse(row, result.status, result.statusText, result.time + 'ms', display);
        })
        .catch(function (err) {
            showResponse(row, 0, 'Network Error', Math.round(performance.now() - start) + 'ms', err.message);
        })
        .finally(function () {
            btn.textContent = 'Test';
            btn.classList.remove('loading');
        });
}

function showResponse(row, status, statusText, time, body) {
    var old = row.querySelector('.response-panel');
    if (old) old.remove();
    var oldParams = row.querySelector('.param-row');
    if (oldParams) oldParams.remove();

    var cls = 'status-err';
    if (status >= 200 && status < 300) cls = 'status-2xx';
    else if (status >= 300 && status < 400) cls = 'status-3xx';
    else if (status >= 400 && status < 500) cls = 'status-4xx';
    else if (status >= 500) cls = 'status-5xx';

    var panel = document.createElement('div');
    panel.className = 'response-panel';
    panel.innerHTML =
        '<div class="response-meta">' +
            '<span class="status-badge ' + cls + '">' + (status || 'ERR') + ' ' + statusText + '</span>' +
            '<span class="response-time">' + time + '</span>' +
            '<button class="close-btn" onclick="closeResponse(this)">&times; close</button>' +
        '</div>' +
        '<div class="response-body">' + escapeHtml(body) + '</div>';
    row.appendChild(panel);
}

function closeResponse(btn) {
    var row = btn.closest('.route-row');
    var panel = row.querySelector('.response-panel');
    if (panel) panel.remove();
    var params = row.querySelector('.param-row');
    if (params) params.remove();
    row.classList.remove('active');
    var testBtn = row.querySelector('.test-btn');
    if (testBtn) testBtn.textContent = 'Test';
}

function escapeHtml(text) {
    var div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
}
</script>
</body>
</html>